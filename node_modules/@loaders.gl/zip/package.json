{
  "name": "@loaders.gl/zip",
  "version": "4.4.3",
  "description": "Zip Archive Loader",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/visgl/loaders.gl"
  },
  "keywords": [
    "webgl",
    "loader",
    "archive",
    "ZIP"
  ],
  "types": "dist/index.d.ts",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "scripts": {
    "pre-build": "npm run build-bundle && npm run build-bundle-dev",
    "build-bundle": "ocular-bundle ./bundle.ts --output=dist/dist.min.js",
    "build-bundle-dev": "ocular-bundle ./bundle.ts --env=dev --output=dist/dist.dev.js"
  },
  "dependencies": {
    "@loaders.gl/compression": "4.4.3",
    "@loaders.gl/crypto": "4.4.3",
    "@loaders.gl/loader-utils": "4.4.3",
    "jszip": "^3.1.5",
    "md5": "^2.3.0"
  },
  "peerDependencies": {
    "@loaders.gl/core": "~4.4.0"
  },
  "gitHead": "8fe7868144ab9ad51f66505b04d772f48b8d0eec"
}
